{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "File": {
      "Path": "Logs/smartmeter-log-.txt",
      "RollingInterval": "Day"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "your-database-connection"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "UserName": "your-username",
    "Password": "your-password"
  },
  "AllowedHosts": "*",
  "AppBaseUrl": "https://localhost:7210",
  "EmailSettings": {
    "SmtpServer": "localhost",
    "Port": 25,
    "SenderName": "Smart Meter System (Test)",
    "SenderEmail": "test@smartmeter.local",
    "Password": "your-password"
  },
  "Jwt": {
    "Key": "your_jwt_secret_key",
    "Issuer": "your_app_name",
    "Audience": "your_app_users",
    "DurationInMinutes": 60
  }
}

